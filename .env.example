# ============================================================
# WORK Protocol v4 — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# --- Required ---

# Postgres 16 connection string
DATABASE_URL=postgresql://workprotocol:workprotocol@localhost:5432/workprotocol

# Base network: base-mainnet or base-sepolia
BASE_NETWORK=base-sepolia

# 32-byte hex key used to encrypt the Ed25519 signing key in the database.
# Generate with: openssl rand -hex 32
SIGNING_KEY_ENCRYPTION_KEY=

# --- CDP x402 (primary payment rail — zero gas, 1,000 free tx/month) ---
# From Coinbase Developer Platform: https://portal.cdp.coinbase.com
CDP_API_KEY_NAME=organizations/.../apiKeys/...
CDP_API_KEY_PRIVATE_KEY=-----BEGIN EC PRIVATE KEY-----

# --- Protocol ---

# Protocol fee in basis points (300 = 3%). Fee is applied to worker payout ONLY.
WORK_PROTOCOL_FEE_BPS=300

# Base L2 vault address that receives protocol fees
BASE_VAULT_ADDRESS=0x0000000000000000000000000000000000000000

# --- Optional: On-chain fallback via viem (pays gas) ---
# If CDP x402 is unavailable, settlement falls back to direct on-chain transfer.
# Leave empty to disable fallback (CDP-only mode).
BASE_SETTLEMENT_PRIVATE_KEY=

# --- Rate Limiting ---

# Public endpoints (no auth): requests per minute
RATE_LIMIT_PUBLIC_RPM=30

# Authenticated endpoints: requests per minute
RATE_LIMIT_AUTHED_RPM=300
